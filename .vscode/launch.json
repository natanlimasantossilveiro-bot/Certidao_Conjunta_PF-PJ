{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI Debug",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--reload"
            ],
            "jinja": true,
            "justMyCode": true,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Uvicorn running on (https?://\\S+)"
            }
        }
    ]
}